{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "streamlit-app",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "streamlit", "run", "app/streamlit_app.py", "--server.port", "8501"],
      "port": 8501
    },
    {
      "name": "fastapi-app",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "api.main:app", "--reload", "--port", "8000", "--app-dir", "app"],
      "port": 8000
    }
  ]
}
